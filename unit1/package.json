{
  "name": "unit1",
  "version": "1.0.0",
  "description": "TEC2/Unit1 - source code",
  "type": "module",
  "scripts": {
    "dev": "tsx ./src/main.ts",
    "start": "node ./build/main.js",
    "build": "rimraf ./build && tsc --project ./tsconfig.build.json && tsc-alias",
    "type:check": "tsc --noEmit --project ./tsconfig.json && tsc --noEmit --project ./tsconfig.test.json",
    "lint": "eslint . --cache",
    "lint:ci": "eslint . --cache --max-warnings=0",
    "lint-staged": "lint-staged",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run --passWithNoTests",
    "test:ci": "vitest run --coverage --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "check": "yarn format:check && yarn lint && yarn type:check && yarn test",
    "check:ci": "yarn format:check && yarn lint:ci && yarn type:check && yarn test:ci"
  },
  "private": true,
  "keywords": [],
  "author": "Eyder Rios",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "yarn@1.22.22",
  "dependencies": {
    "change-case": "^5.4.4",
    "dotenv": "^16"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/eslint-plugin": "^1.6.12",
    "eslint": "^9",
    "eslint-config-prettier": "^9",
    "eslint-import-resolver-typescript": "^3",
    "eslint-plugin-import": "^2",
    "eslint-plugin-n": "^17",
    "eslint-plugin-promise": "^7",
    "lint-staged": "^15",
    "prettier": "^3",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1",
    "tsconfig-paths": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0",
    "vitest-mock-extended": "^3.1.0"
  }
}
